<?xml version="1.0" encoding="utf-8"?>
<!--
  ~ Cloud backup / data extraction rules (Android 12+).
  ~ Exclude the Room database from cloud backup to avoid syncing
  ~ stale cell tower data to new devices.
  -->
<data-extraction-rules>
    <cloud-backup>
        <exclude domain="database" path="edge_sentinel.db" />
        <exclude domain="database" path="edge_sentinel.db-wal" />
        <exclude domain="database" path="edge_sentinel.db-shm" />
    </cloud-backup>
    <device-transfer>
        <include domain="database" path="." />
        <include domain="sharedpref" path="." />
    </device-transfer>
</data-extraction-rules>
